{%- comment -%}
  product-card.liquid — Snippet responsive
  Mobile: imagen compacta + nombre + precio + botón grande
  Desktop: imagen + spec bar + desc + hover effects
{%- endcomment -%}

{% assign badge_tag = '' %}
{% assign badge_class = '' %}
{% for tag in product.tags %}
  {% if tag == 'viral' %}{% assign badge_tag = 'VIRAL' %}{% assign badge_class = 'badge-viral' %}{% endif %}
  {% if tag == 'nuevo' %}{% assign badge_tag = 'NUEVO' %}{% assign badge_class = 'badge-new' %}{% endif %}
  {% if tag == 'hot' %}{% assign badge_tag = 'HOT' %}{% assign badge_class = 'badge-hot' %}{% endif %}
  {% if tag == 'oferta' %}{% assign badge_tag = 'OFERTA' %}{% assign badge_class = 'badge-sale' %}{% endif %}
{% endfor %}

{% assign compare_price = product.compare_at_price %}
{% assign sale_price = product.price %}
{% assign discount_pct = 0 %}
{% if compare_price > sale_price %}
  {% assign diff = compare_price | minus: sale_price %}
  {% assign discount_pct = diff | times: 100 | divided_by: compare_price %}
{% endif %}

{%- comment -%} Colección para tabs filter {%- endcomment -%}
{% assign collection_tag = '' %}
{% for tag in product.tags %}
  {% if tag == 'flash-deals' or tag == 'tech-solutions' or tag == 'top-ventas' %}
    {% assign collection_tag = tag %}
  {% endif %}
{% endfor %}

<article
  class="product-card"
  role="listitem"
  data-product-id="{{ product.id }}"
  data-collection="{{ collection_tag }}"
>
  {%- comment -%} IMAGEN — link al producto {%- endcomment -%}
  <a href="{{ product.url }}" class="product-card__media" tabindex="-1" aria-hidden="true">
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape | default: product.title }}"
        loading="lazy"
        width="600"
        height="450"
      >
    {% else %}
      <div style="width:100%;height:100%;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    {% endif %}

    {% if badge_tag != '' %}
      <div class="product-card__badges">
        <span class="badge {{ badge_class }}">{{ badge_tag }}</span>
      </div>
    {% endif %}

    {% if discount_pct > 0 %}
      <div class="product-card__badges" style="{% if badge_tag != '' %}top:40px;{% endif %}">
        <span class="badge badge-sale">-{{ discount_pct }}%</span>
      </div>
    {% endif %}
  </a>

  {%- comment -%} BODY {%- endcomment -%}
  <div class="product-card__body">
    <span class="product-card__category">{{ product.type | default: 'Tech' }}</span>

    <h3 class="product-card__name">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    {%- comment -%} Descripción — visible desde tablet {%- endcomment -%}
    <p class="product-card__desc">
      {{ product.description | strip_html | truncate: 90 }}
    </p>

    <div class="product-card__pricing">
      <span class="price-current">{{ sale_price | money }}</span>
      {% if compare_price > sale_price %}
        <span class="price-original">{{ compare_price | money }}</span>
      {% endif %}
    </div>
  </div>

  {%- comment -%} SPEC BAR — solo desde tablet {%- endcomment -%}
  <div class="product-card__spec-bar">
    <div class="spec-item">
      <span class="spec-item__label">Entrega</span>
      <span class="spec-item__value">Nacional</span>
    </div>
    <div class="spec-item">
      <span class="spec-item__label">Garantía</span>
      <span class="spec-item__value">7 días</span>
    </div>
    <div class="spec-item">
      <span class="spec-item__label">Pago</span>
      <span class="spec-item__value">Online</span>
    </div>
  </div>

  {%- comment -%} FOOTER — botones de acción {%- endcomment -%}
  <div class="product-card__footer">
    <button
      class="btn btn-primary btn-sm"
      data-add-to-cart="{{ product.variants.first.id }}"
      aria-label="Agregar {{ product.title | escape }} al carrito"
      {% unless product.available %}disabled{% endunless %}
    >
      {% if product.available %}
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        Comprar
      {% else %}
        Agotado
      {% endif %}
    </button>
    <a href="{{ product.url }}" class="btn btn-outline btn-sm" aria-label="Ver detalles de {{ product.title | escape }}">
      Ver
    </a>
  </div>
</article>
