{{ 'section-info-page.css' | asset_url | stylesheet_tag }}

{%- assign key = template.suffix | default: 'info' -%}

<!-- ── Títulos dinámicos por página ─── -->
{%- capture title -%}
  {%- case key -%}
    {%- when 'como-comprar' -%}Como comprar
    {%- when 'envios' -%}Envíos
    {%- when 'garantia' -%}Garantía
    {%- when 'devoluciones' -%}Devoluciones
    {%- else -%}Nosotros
  {%- endcase -%}
{%- endcapture -%}

{%- capture subtitle -%}
  {%- case key -%}
    {%- when 'como-comprar' -%}Compra online en minutos, con total confianza.
    {%- when 'envios' -%}Envíos a Colombia con seguimiento. Tiempos según ciudad.
    {%- when 'garantia' -%}Tu compra está protegida. Te acompañamos si algo no sale bien.
    {%- when 'devoluciones' -%}Proceso claro y simple. Sin letras pequeñas.
    {%- else -%}Tecnología útil, atención real y compras seguras para tu día a día.
  {%- endcase -%}
{%- endcapture -%}

<section class="info-page section" aria-labelledby="info-page-title">
  <div class="container info-page__container">

    <!-- Encabezado de página -->
    <header class="info-page__header" data-animate>
      <span class="tag">Inge Shop</span>
      <h1 class="display-md" id="info-page-title">{{ title | strip }}</h1>
      <p class="info-page__subtitle">{{ subtitle | strip }}</p>
    </header>

    <!-- ══════════════════════════════════════════════════
         MODO "NOSOTROS" — Misión, Visión y Valores
    ══════════════════════════════════════════════════ -->
    {%- if key == 'info' or key == blank -%}

      <!-- Misión + Visión en grid -->
      <div class="ip-mv-grid">

        <!-- Misión -->
        <article class="ip-card ip-card--mission" aria-label="Nuestra Misión">
          <div class="ip-card__icon-wrap">
            <svg class="ip-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="4"/>
              <line x1="12" y1="2"  x2="12" y2="6"/>
              <line x1="12" y1="18" x2="12" y2="22"/>
              <line x1="2"  y1="12" x2="6"  y2="12"/>
              <line x1="18" y1="12" x2="22" y2="12"/>
            </svg>
          </div>
          <div class="ip-card__body">
            <p class="ip-card__label">Nuestra Misión</p>
            <h2 class="ip-card__title">Tecnología útil, al alcance de todos</h2>
            <p class="ip-card__text">
              En Inge Shop llevamos micrófonos, periféricos y gadgets de alta calidad directamente a tus manos — sin complicaciones ni precios inflados. Cada producto que ofrecemos lo elegimos porque resuelve algo real: una videoconferencia más profesional, más productividad, más comodidad en tu día a día.
            </p>
            <p class="ip-card__text">
              Compramos bien para que tú compres mejor. Y si algo no te convence, estamos a un WhatsApp de distancia — como si le compraras a un amigo que sabe de tecnología.
            </p>
          </div>
        </article>

        <!-- Visión -->
        <article class="ip-card ip-card--vision" aria-label="Nuestra Visión">
          <div class="ip-card__icon-wrap">
            <svg class="ip-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div class="ip-card__body">
            <p class="ip-card__label">Nuestra Visión</p>
            <h2 class="ip-card__title">La tienda tech de confianza en Colombia</h2>
            <p class="ip-card__text">
              Queremos que cuando alguien en Colombia piense en comprar tecnología con seguridad, piense en Inge Shop — no por publicidad, sino porque un amigo se la recomendó.
            </p>
            <p class="ip-card__text">
              Estamos construyendo una marca que crece con sus clientes: más productos, mejor servicio y la misma cercanía que nos define desde el primer día. El objetivo no es ser la tienda más grande, sino la más confiable.
            </p>
          </div>
        </article>

      </div><!-- /ip-mv-grid -->

      <!-- Divisor -->
      <div class="ip-divider" aria-hidden="true">
        <span class="ip-divider__line"></span>
        <span class="ip-divider__label">Nuestros Valores</span>
        <span class="ip-divider__line"></span>
      </div>

      <!-- Valores -->
      <div class="ip-values" aria-label="Nuestros valores">

        <div class="ip-value" data-animate>
          <div class="ip-value__icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="ip-value__title">Transparencia total</h3>
          <p class="ip-value__desc">Precios claros, garantías reales y sin sorpresas al finalizar la compra. Lo que ves es lo que pagas.</p>
        </div>

        <div class="ip-value" data-animate>
          <div class="ip-value__icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="ip-value__title">Atención que sí responde</h3>
          <p class="ip-value__desc">Soporte humano, rápido y directo. Sin bots que no entienden ni esperas de días. Te respondemos.</p>
        </div>

        <div class="ip-value" data-animate>
          <div class="ip-value__icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 11 12 14 22 4"/>
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
          </div>
          <h3 class="ip-value__title">Calidad antes que cantidad</h3>
          <p class="ip-value__desc">Solo vendemos lo que probamos y recomendaríamos. Menos catálogo, más confianza en cada producto.</p>
        </div>

        <div class="ip-value" data-animate>
          <div class="ip-value__icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3 class="ip-value__title">Compromiso real</h3>
          <p class="ip-value__desc">Cumplimos con los envíos, las garantías y las promesas. Lo que decimos, lo hacemos.</p>
        </div>

        <div class="ip-value" data-animate>
          <div class="ip-value__icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <h3 class="ip-value__title">Tecnología sin enredos</h3>
          <p class="ip-value__desc">Te explicamos todo en palabras normales. Sin tecnicismos innecesarios ni lenguaje que confunda.</p>
        </div>

      </div><!-- /ip-values -->

      <!-- CTA final -->
      <div class="ip-cta-wrap">
        <div class="ip-cta-card">
          <p class="ip-cta-card__eyebrow">¿Tienes dudas?</p>
          <h2 class="ip-cta-card__title">Hablemos por WhatsApp</h2>
          <p class="ip-cta-card__desc">Te asesoramos en minutos. Sin compromisos, sin formularios complicados.</p>
          <a href="https://wa.me/{{ section.settings.whatsapp_number }}"
             target="_blank" rel="noopener"
             class="btn btn-primary btn-lg"
             id="ip-whatsapp-cta">
            Escribir ahora →
          </a>
        </div>
      </div>

    <!-- ══════════════════════════════════════════════════
         OTRAS PÁGINAS (como comprar, envíos, etc.)
    ══════════════════════════════════════════════════ -->
    {%- else -%}

      <div class="info-page__grid">
        <div class="info-page__content body-md text-secondary">
          {%- case key -%}
            {%- when 'como-comprar' -%}
              <ol class="info-page__steps">
                <li><strong>Elige tu producto</strong> y revisa la información.</li>
                <li><strong>Añade al carrito</strong> y completa tus datos.</li>
                <li><strong>Paga online</strong> con pasarela segura.</li>
                <li><strong>Recibe confirmación</strong> y seguimiento de tu envío.</li>
              </ol>
            {%- when 'envios' -%}
              <ul class="info-page__bullets">
                <li>Envíos a Colombia con <strong>seguimiento incluido</strong>.</li>
                <li>El tiempo de entrega varía por ciudad y operador logístico.</li>
                <li>Te notificamos el estado del pedido por WhatsApp o email.</li>
              </ul>
            {%- when 'garantia' -%}
              <ul class="info-page__bullets">
                <li><strong>Garantía de satisfacción</strong> y soporte directo.</li>
                <li>Si presentas un inconveniente, te guiamos paso a paso.</li>
                <li>Escríbenos por WhatsApp y lo resolvemos rápido.</li>
              </ul>
            {%- when 'devoluciones' -%}
              <ul class="info-page__bullets">
                <li>Devoluciones con proceso claro y acompañamiento.</li>
                <li>Cuéntanos el caso por WhatsApp y te indicamos el siguiente paso.</li>
                <li>Queremos que compres con confianza, siempre.</li>
              </ul>
            {%- else -%}
              <p>Esta página está en construcción.</p>
          {%- endcase -%}
        </div>

        <aside class="info-page__aside" aria-label="Contacto">
          <div class="info-page__card">
            <p class="info-page__card-title">¿Necesitas ayuda?</p>
            <p class="info-page__card-desc">Te asesoramos en minutos por WhatsApp.</p>
            <a class="info-page__cta btn btn-primary btn-lg"
               href="https://wa.me/{{ section.settings.whatsapp_number }}"
               target="_blank" rel="noopener">
              Hablar por WhatsApp
            </a>
            <div class="info-page__trust">
              <div class="info-page__trust-item">✓ Pagos 100% seguros</div>
              <div class="info-page__trust-item">✓ Soporte directo</div>
              <div class="info-page__trust-item">✓ Garantía incluida</div>
            </div>
          </div>
        </aside>
      </div>

    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Info Page",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Número WhatsApp",
      "default": "573150850759",
      "info": "Número con código de país, sin +. Ej: 573150850759."
    }
  ],
  "presets": [{ "name": "Info Page" }]
}
{% endschema %}
