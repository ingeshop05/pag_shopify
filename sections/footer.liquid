{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="footer" role="contentinfo">
  {%- assign contact_whatsapp = section.settings.whatsapp_number | default: '573150850759' -%}
  {%- assign contact_email = section.settings.email | default: 'ingeshop.05@gmail.com' -%}
  {%- assign contact_instagram = section.settings.instagram_url | default: 'https://instagram.com/ingeshop_oficial' -%}
  {%- assign contact_facebook = section.settings.facebook_url | default: 'https://web.facebook.com/share/p/18sM5vouWL/' -%}
  <div class="footer__grid">
    <div>
      <div class="footer__brand-name">Inge<span class="text-accent">Shop</span></div>
      <p class="footer__brand-desc">
        Tecnología inteligente para el día a día colombiano.
        Productos seleccionados, entrega rápida y pagos online seguros.
      </p>

      <div class="footer__trust" aria-label="Confianza y seguridad">
        <div class="footer__trust-item">
          <svg class="footer__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <path d="M9 12l2 2 4-4"/>
          </svg>
          Pagos 100% seguros
        </div>
        <div class="footer__trust-item">
          <svg class="footer__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          Garantía de satisfacción
        </div>
        <div class="footer__trust-item">
          <svg class="footer__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Soporte directo
        </div>
      </div>

      <div class="footer__social">
        <a href="{{ contact_facebook }}" class="social-btn" aria-label="Facebook" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="{{ contact_instagram }}" class="social-btn" aria-label="Instagram" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://wa.me/{{ contact_whatsapp }}" class="social-btn" aria-label="WhatsApp" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        {% if section.settings.tiktok_url != blank %}
          <a href="{{ section.settings.tiktok_url }}" class="social-btn" aria-label="TikTok" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.73z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <div>
      <p class="footer__col-title">Productos</p>
      <ul class="footer__links">
        <li><a href="{{ routes.all_products_collection_url }}/flash-deals" class="footer__link">Flash Deals</a></li>
        <li><a href="{{ routes.all_products_collection_url }}/tech-solutions" class="footer__link">Tech Solutions</a></li>
        <li><a href="{{ routes.all_products_collection_url }}/top-ventas" class="footer__link">Top Ventas</a></li>
        <li><a href="{{ routes.all_products_collection_url }}"    class="footer__link">Todos</a></li>
      </ul>
    </div>

    <div>
      <p class="footer__col-title">Información</p>
      <ul class="footer__links">
        {% comment %} 
          IMPORTANTE: Para que estos enlaces funcionen (no den 404), 
          debes crear las páginas en el Admin de Shopify (Tienda online > Páginas) 
          con los siguientes identificadores (handles):
          - informacion
          - como-comprar
          - envios
          - garantia
          - contacto
        {% endcomment %}
        <li><a href="{{ pages['informacion'].url | default: '/pages/informacion' }}" class="footer__link">Información General</a></li>
        <li><a href="{{ pages['como-comprar'].url | default: '/pages/como-comprar' }}" class="footer__link">Cómo comprar</a></li>
        <li><a href="{{ pages['envios'].url | default: '/pages/envios' }}" class="footer__link">Envíos</a></li>
        <li><a href="{{ pages['garantia'].url | default: '/pages/garantia' }}" class="footer__link">Garantía</a></li>
        <li><a href="{{ pages['contacto'].url | default: '/pages/contacto' }}" class="footer__link">Contacto</a></li>
      </ul>
    </div>

    <div>
      <p class="footer__col-title">Contacto</p>
      <div class="footer__contact">
        <a href="https://wa.me/{{ contact_whatsapp }}" class="footer__contact-btn" target="_blank" rel="noopener">
            <svg class="footer__contact-btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        <a href="mailto:{{ contact_email }}" class="footer__contact-btn">
            <svg class="footer__contact-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 4h16v16H4z"/><path d="m4 4 8 8 8-8"/>
            </svg>
            Email
          </a>
        <a href="{{ contact_instagram }}" class="footer__contact-btn" target="_blank" rel="noopener">
            <svg class="footer__contact-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            Instagram
          </a>
        <a href="/pages/contacto" class="footer__contact-btn">
            <svg class="footer__contact-btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            Ver más opciones
          </a>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <span class="footer__copyright">© {{ 'now' | date: '%Y' }} Inge Shop — Todos los derechos reservados</span>
    <span class="footer__made mono text-muted">Hecho con 💻 en Colombia</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp (con código país, sin +)", "default": "573150850759", "info": "Ej: 573150850759" },
    { "type": "text", "id": "email",           "label": "Email",                              "default": "ingeshop.05@gmail.com" },
    { "type": "text", "id": "instagram_url",   "label": "Instagram URL",                      "default": "https://instagram.com/ingeshop_oficial" },
    { "type": "text", "id": "facebook_url",    "label": "Facebook URL",                       "default": "https://web.facebook.com/share/p/18sM5vouWL/" },
    { "type": "text", "id": "tiktok_url",      "label": "TikTok URL" }
  ]
}
{% endschema %}
