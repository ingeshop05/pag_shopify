<section class="problem-solution section" id="soluciones" aria-labelledby="ps-title">
  <div class="container">
    <div class="ps-grid">
      <div class="ps-visual" aria-hidden="true">
        <div class="ps-visual__code">
<span class="cm">// Sistema Inge Shop</span><br>
<span class="kw">const</span> order = {<br>
&nbsp;&nbsp;cliente: <span class="str">"Tú"</span>,<br>
&nbsp;&nbsp;estado: <span class="str">"confirmado"</span>,<br>
&nbsp;&nbsp;pago: <span class="str">"online"</span>,<br>
&nbsp;&nbsp;garantia: <span class="str">"7 días"</span><br>
};<br><br>
<span class="cm">// Proceso automatizado</span><br>
<span class="kw">function</span> <span class="str">dispatch</span>(order) {<br>
&nbsp;&nbsp;validate(order.cliente);<br>
&nbsp;&nbsp;<span class="kw">return</span> {<br>
&nbsp;&nbsp;&nbsp;&nbsp;status: <span class="str">"enviado"</span>,<br>
&nbsp;&nbsp;&nbsp;&nbsp;status_pago: <span class="str">"confirmado"</span><br>
&nbsp;&nbsp;};<br>
}
        </div>
      </div>

      <div class="ps-features" data-animate>
        <span class="tag">{{ section.settings.eyebrow }}</span>
        <h2 class="display-md" id="ps-title" style="margin:1rem 0;">
          {{ section.settings.title }}<br>
          <span class="text-accent">{{ section.settings.title_accent }}</span>
        </h2>
        {% for i in (1..4) %}
          {% assign title_key = 'feature_' | append: i | append: '_title' %}
          {% assign desc_key  = 'feature_' | append: i | append: '_desc' %}
          <div class="ps-feature">
            <div class="ps-feature__icon">
              {% case i %}
                {% when 1 %}
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {% when 2 %}
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                {% when 3 %}
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.53 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l1.97-1.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {% when 4 %}
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {% endcase %}
            </div>
            <div>
              <p class="ps-feature__title">{{ section.settings[title_key] }}</p>
              <p class="ps-feature__desc">{{ section.settings[desc_key] }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Problem Solution",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "¿Por qué Inge Shop?" },
    { "type": "text", "id": "title", "label": "Título", "default": "Sin riesgos." },
    { "type": "text", "id": "title_accent", "label": "Título acento", "default": "Sin complicaciones." },
    { "type": "text", "id": "feature_1_title", "label": "Feature 1 título", "default": "Pago 100% seguro" },
    { "type": "textarea", "id": "feature_1_desc", "label": "Feature 1 descripción", "default": "Pagos online protegidos con pasarelas seguras. Compra con total confianza." },
    { "type": "text", "id": "feature_2_title", "label": "Feature 2 título", "default": "Productos verificados" },
    { "type": "textarea", "id": "feature_2_desc", "label": "Feature 2 descripción", "default": "Cada producto pasa por un proceso de selección riguroso." },
    { "type": "text", "id": "feature_3_title", "label": "Feature 3 título", "default": "Soporte directo" },
    { "type": "textarea", "id": "feature_3_desc", "label": "Feature 3 descripción", "default": "Atención personalizada por WhatsApp." },
    { "type": "text", "id": "feature_4_title", "label": "Feature 4 título", "default": "Entrega express" },
    { "type": "textarea", "id": "feature_4_desc", "label": "Feature 4 descripción", "default": "Envíos a Colombia con seguimiento. Tiempos de entrega según ciudad." }
  ],
  "presets": [{ "name": "Problem Solution" }]
}
{% endschema %}
