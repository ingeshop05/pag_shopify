<section class="products-section section" id="productos" aria-labelledby="products-title">
  <div class="container">

    <!-- Encabezado -->
    <div class="section-header" data-animate>
      <div class="section-header__left">
        <span class="tag section-header__eyebrow">{{ section.settings.eyebrow | default: 'Catálogo' }}</span>
        <h2 class="display-md" id="products-title">
          {{ section.settings.title }}<br>
          <span class="text-accent">{{ section.settings.title_accent }}</span>
        </h2>
        <p class="body-md text-secondary">{{ section.settings.subtitle }}</p>
      </div>
      <a href="{{ routes.collections_url }}/all" class="btn btn-outline hide-mobile">Ver todo el catálogo</a>
    </div>

    <!-- Carrusel -->
    {% assign col_handle = section.settings.collection | default: 'all' %}
    {% assign prod_limit = section.settings.products_to_show | default: 8 %}
    {% assign col_products = collections[col_handle].products %}

    {% if col_products.size > 0 %}
      <div class="fp-carousel" id="fp-carousel">

        <!-- Flechas -->
        <button class="fp-carousel__arrow fp-carousel__arrow--prev" id="fp-prev" aria-label="Anterior">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="fp-carousel__arrow fp-carousel__arrow--next" id="fp-next" aria-label="Siguiente">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <!-- Viewport -->
        <div class="fp-carousel__viewport" id="fp-viewport">
          <div class="fp-carousel__track" id="fp-track">

            {% for product in col_products limit: prod_limit %}
              <div class="fp-carousel__slide" role="group" aria-label="Producto {{ forloop.index }}">
                <a href="{{ product.url }}" class="fp-prod-card" title="{{ product.title }}">

                  <div class="fp-prod-card__media">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | default: product.title }}"
                        class="fp-prod-card__img"
                        loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                        width="600" height="600">
                    {% else %}
                      <div class="fp-prod-card__placeholder">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                      </div>
                    {% endif %}

                    {% if product.compare_at_price > product.price %}
                      <span class="fp-prod-card__badge fp-prod-card__badge--sale">Oferta</span>
                    {% endif %}

                    <div class="fp-prod-card__overlay">
                      <span class="fp-prod-card__overlay-cta">Ver producto →</span>
                    </div>
                  </div>

                  <div class="fp-prod-card__body">
                    {% if product.vendor != blank %}
                      <p class="fp-prod-card__vendor">{{ product.vendor }}</p>
                    {% endif %}
                    <h3 class="fp-prod-card__title">{{ product.title }}</h3>
                    <div class="fp-prod-card__pricing">
                      <span class="fp-prod-card__price">{{ product.price | money }}</span>
                      {% if product.compare_at_price > product.price %}
                        <span class="fp-prod-card__compare">{{ product.compare_at_price | money }}</span>
                      {% endif %}
                    </div>
                  </div>

                </a>
              </div>
            {% endfor %}

          </div><!-- /track -->
        </div><!-- /viewport -->

        <!-- Dots -->
        <div class="fp-carousel__dots" id="fp-dots" role="tablist" aria-label="Posición en el carrusel"></div>

      </div><!-- /fp-carousel -->

    {% else %}
      <p class="text-secondary" style="text-align:center;padding:4rem 0;">
        No hay productos en esta colección todavía.
      </p>
    {% endif %}

  </div>
</section>

<!-- JS del carrusel -->
<script>
(function () {
  'use strict';

  var AUTOPLAY_MS = {{ section.settings.autoplay_speed | default: 0 }};
  var GAP = 20;

  var viewport  = document.getElementById('fp-viewport');
  var track     = document.getElementById('fp-track');
  var dotsWrap  = document.getElementById('fp-dots');
  var btnPrev   = document.getElementById('fp-prev');
  var btnNext   = document.getElementById('fp-next');
  var carousel  = document.getElementById('fp-carousel');

  if (!track || !viewport) return;

  var slides  = Array.from(track.children);
  var total   = slides.length;
  var current = 0;
  var timer   = null;

  function cpv() {
    if (window.innerWidth >= 1024) return 4;
    if (window.innerWidth >= 640)  return 2;
    return 1;
  }

  function cardW() {
    return slides[0].offsetWidth + GAP;
  }

  function maxIdx() {
    return Math.max(0, total - cpv());
  }

  function goTo(idx) {
    current = Math.max(0, Math.min(idx, maxIdx()));
    track.style.transform = 'translateX(-' + (current * cardW()) + 'px)';
    updateDots();
    btnPrev.disabled = current === 0;
    btnNext.disabled = current >= maxIdx();
    btnPrev.style.opacity = btnPrev.disabled ? '0.35' : '1';
    btnNext.style.opacity = btnNext.disabled ? '0.35' : '1';
  }

  function buildDots() {
    dotsWrap.innerHTML = '';
    var pages = maxIdx() + 1;
    for (var i = 0; i < pages; i++) {
      var btn = document.createElement('button');
      btn.className = 'fp-dot' + (i === 0 ? ' is-active' : '');
      btn.setAttribute('role', 'tab');
      btn.setAttribute('aria-label', 'Posición ' + (i + 1));
      btn.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
      btn.dataset.index = i;
      (function(idx) {
        btn.addEventListener('click', function() { goTo(idx); resetAP(); });
      })(i);
      dotsWrap.appendChild(btn);
    }
  }

  function updateDots() {
    Array.from(dotsWrap.children).forEach(function(d, i) {
      var active = i === current;
      d.classList.toggle('is-active', active);
      d.setAttribute('aria-selected', active ? 'true' : 'false');
    });
  }

  function startAP() {
    if (!AUTOPLAY_MS) return;
    timer = setInterval(function() {
      goTo(current >= maxIdx() ? 0 : current + 1);
    }, AUTOPLAY_MS);
  }
  function stopAP()  { clearInterval(timer); }
  function resetAP() { stopAP(); startAP(); }

  btnPrev.addEventListener('click', function() { goTo(current - 1); resetAP(); });
  btnNext.addEventListener('click', function() { goTo(current + 1); resetAP(); });

  carousel.addEventListener('mouseenter', stopAP);
  carousel.addEventListener('mouseleave', startAP);

  var touchX = 0;
  viewport.addEventListener('touchstart', function(e) { touchX = e.touches[0].clientX; }, { passive: true });
  viewport.addEventListener('touchend', function(e) {
    var diff = touchX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { goTo(diff > 0 ? current + 1 : current - 1); resetAP(); }
  });

  var resizeT;
  window.addEventListener('resize', function() {
    clearTimeout(resizeT);
    resizeT = setTimeout(function() { buildDots(); goTo(Math.min(current, maxIdx())); }, 150);
  });

  buildDots();
  goTo(0);
  startAP();
})();
</script>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text",       "id": "eyebrow",           "label": "Eyebrow",             "default": "Catálogo" },
    { "type": "text",       "id": "title",              "label": "Título",              "default": "Productos Seleccionados" },
    { "type": "text",       "id": "title_accent",       "label": "Título acento (cyan)","default": "Seleccionados" },
    { "type": "text",       "id": "subtitle",           "label": "Subtítulo",           "default": "Tecnología validada. Máxima relación calidad–precio." },
    { "type": "collection", "id": "collection",         "label": "Colección",           "info": "Vacío = todos los productos." },
    { "type": "range",      "id": "products_to_show",   "label": "Cantidad de productos","min": 4, "max": 16, "step": 2, "default": 8 },
    { "type": "range",      "id": "autoplay_speed",     "label": "Autoplay ms (0 = off)","min": 0, "max": 8000, "step": 500, "default": 0 }
  ],
  "presets": [{ "name": "Featured Products" }]
 }
{% endschema %}
