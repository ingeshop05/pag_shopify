{{ 'section-product-main.css' | asset_url | stylesheet_tag }}

<section class="product-page section" aria-labelledby="product-title">
  <div class="container">
    <div class="product-page__grid">

      <!-- GALERIA -->
      <div class="product-page__media">
        <div class="product-page__main-image">
          {% if product.featured_image %}
            <img id="product-main-img"
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | escape }}"
              width="800" height="600" loading="eager">
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="product-page__thumbs">
            {% for image in product.images %}
              <button class="product-page__thumb {% if forloop.first %}active{% endif %}"
                data-src="{{ image | image_url: width: 800 }}"
                aria-label="Ver imagen {{ forloop.index }}">
                <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | escape }}" width="120" height="90">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- INFO -->
      <div class="product-page__info">
        <div class="product-page__badges">
          {% for tag in product.tags %}
            {% if tag == 'viral' %}<span class="badge badge-viral">VIRAL</span>{% endif %}
            {% if tag == 'nuevo' %}<span class="badge badge-new">NUEVO</span>{% endif %}
            {% if tag == 'hot'   %}<span class="badge badge-hot">HOT</span>{% endif %}
          {% endfor %}
        </div>

        <p class="product-page__type mono text-muted">{{ product.type }}</p>
        <h1 class="product-page__title display-md" id="product-title">{{ product.title }}</h1>

        <div class="product-page__pricing">
          {% assign compare = product.compare_at_price %}
          {% assign current = product.price %}
          <div class="product-page__price-wrapper">
            <span class="price-current product-page__price-current--lg">{{ current | money }}</span>
            {% if compare > current %}
              <span class="price-original">{{ compare | money }}</span>
              {% assign diff = compare | minus: current %}
              {% assign pct  = diff | times: 100 | divided_by: compare %}
              <span class="price-discount">AHORRA {{ pct }}%</span>
            {% endif %}
          </div>
          <div class="product-page__stock-indicator">
            <div class="stock-dot"></div>
            <span class="stock-text">Disponibilidad Inmediata — <strong>Solo {{ product.variants.first.inventory_quantity | default: 5 }} unidades en stock</strong></span>
          </div>
        </div>

        <div class="product-page__trust-badges">
          <div class="trust-badge-mini">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Calidad Certificada
          </div>
          <div class="trust-badge-mini">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            Garantía de 180 días
          </div>
          <div class="trust-badge-mini">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 5v3h-7V8z"/></svg>
            Envío Express
          </div>
        </div>

        {% form 'product', product, id: 'product-form' %}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">

          {% if product.variants.size > 1 %}
            <div class="product-page__variant-wrapper">
              <label class="product-page__variant-label" for="variant-select">Variante</label>
              <select id="variant-select" name="id" class="variant-select">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }} - {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endif %}

          <div class="product-page__actions">
            <button type="submit" class="btn-cta btn-full" {% unless product.available %}disabled{% endunless %}>
              {% if product.available %}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                Agregar al carrito
              {% else %}
                Agotado
              {% endif %}
            </button>
            <a href="https://wa.me/{{ section.settings.whatsapp_number }}?text=Hola!%20Quiero%20pedir%3A%20{{ product.title | url_encode }}"
               class="btn btn-outline btn-full product-page__whatsapp-btn"
               target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Pedir por WhatsApp
            </a>
          </div>
        {% endform %}

        <div class="product-page__description product-page__description-section">
          {{ product.description }}
        </div>
      </div>

    </div>
  </div>

  <!-- STICKY CTA MOBILE - manejado por cart.js > bindStickyCTA() -->
  <div class="product-sticky-cta" aria-label="Compra rapida">
    <div class="product-sticky-cta__price">{{ product.price | money }}</div>
    <button class="btn-cta" style="flex:1;">
      Agregar al carrito
    </button>
  </div>
</section>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Numero WhatsApp",
      "default": "573000000000",
      "info": "Numero con codigo de pais, sin +. Ej: 573150850759. Se usa en el boton 'Pedir por WhatsApp' de cada producto."
    }
  ],
  "presets": [{ "name": "Product Main" }]
}
{% endschema %}
